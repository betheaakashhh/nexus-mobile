{
  "expo": {
    "name": "Nexus",
    "slug": "nexus-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nexus",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1c1b19"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1b19"
      },
      "package": "com.aethersolve.nexus",
      "permissions": [
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", {
        "cameraPermission": "Allow Nexus to access your camera for document scanning."
      }],
      ["expo-contacts", {
        "contactsPermission": "Allow Nexus to read contacts for auto-sync to your dashboard."
      }],
      ["expo-notifications", {
        "color": "#c9a96e"
      }],
      "expo-background-fetch",
      "expo-sqlite"
    ],
    "experiments": { "typedRoutes": true }
  }
}